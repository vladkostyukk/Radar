<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Widget.App.NavigationView" parent="Widget.Material3.NavigationView">
        <item name="itemIconTint">@color/black</item>
        <item name="itemTextColor">@color/black</item>
        <item name="itemShapeFillColor">@color/nav_item_bg_color</item>
    </style>

    <style name="NavigationMenuTextStyle" parent="android:Widget.TextView">
        <item name="android:textSize">20sp</item>
    </style>

    <style name="PopupMenuStyle" parent="Widget.AppCompat.PopupMenu">
        <item name="android:textColor">@color/black</item>
        <item name="popupMenuBackground">@color/white</item>
    </style>

    <style name="MaterialCalendar" parent="ThemeOverlay.MaterialComponents.MaterialCalendar">
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimary">@color/carrot_orange</item>
    </style>

</resources>